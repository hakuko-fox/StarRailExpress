{
  "multipart": [
    {
      "when": { "half": "lower", "facing": "north" },
      "apply": { "model": "starrailexpress:block/ticket_gate_lower" }
    },
    {
      "when": { "half": "lower", "facing": "east" },
      "apply": { "model": "starrailexpress:block/ticket_gate_lower", "y": 90 }
    },
    {
      "when": { "half": "lower", "facing": "south" },
      "apply": { "model": "starrailexpress:block/ticket_gate_lower", "y": 180 }
    },
    {
      "when": { "half": "lower", "facing": "west" },
      "apply": { "model": "starrailexpress:block/ticket_gate_lower", "y": 270 }
    },
    {
      "when": { "half": "upper", "facing": "north" },
      "apply": { "model": "starrailexpress:block/ticket_gate_upper" }
    },
    {
      "when": { "half": "upper", "facing": "east" },
      "apply": { "model": "starrailexpress:block/ticket_gate_upper", "y": 90 }
    },
    {
      "when": { "half": "upper", "facing": "south" },
      "apply": { "model": "starrailexpress:block/ticket_gate_upper", "y": 180 }
    },
    {
      "when": { "half": "upper", "facing": "west" },
      "apply": { "model": "starrailexpress:block/ticket_gate_upper", "y": 270 }
    }
  ]
}
